{
  "name": "scalpel",
  "version": "1.0.0-alpha.1",
  "description": "Precise, atomic file editing for code and text over MCP.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0langa/scalpel.git"
  },
  "bugs": {
    "url": "https://github.com/0langa/scalpel/issues"
  },
  "homepage": "https://github.com/0langa/scalpel#readme",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "scalpel": "./dist/index.js"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:mcp-smoke": "tsx scripts/mcp-smoke.ts",
    "test:package-smoke": "tsx scripts/package-smoke.ts",
    "hardening:setup": "tsx scripts/hardening.ts setup",
    "hardening:corpus": "tsx scripts/hardening.ts corpus",
    "hardening:race": "tsx scripts/hardening.ts race",
    "hardening:crash": "tsx scripts/hardening.ts crash",
    "hardening:all": "tsx scripts/hardening.ts all",
    "validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:mcp-smoke && pnpm test:package-smoke",
    "test:watch": "vitest",
    "inspector": "npx @modelcontextprotocol/inspector"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "diff": "9.0.0",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.1",
    "eslint": "10.4.1",
    "fast-check": "4.8.0",
    "memfs": "4.57.6",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8"
  }
}
