{
  "name": "scalpel",
  "version": "0.1.0",
  "private": true,
  "description": "Precise, atomic file editing for code and text over MCP.",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspector": "npx @modelcontextprotocol/inspector"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "diff": "9.0.0",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.1",
    "eslint": "10.4.1",
    "fast-check": "4.8.0",
    "memfs": "4.57.6",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8"
  }
}
